# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook secrets
DMGURU_WEBHOOK_SECRET=mf_guru_2024
HOTMART_WEBHOOK_SECRET=your-hotmart-secret
EDUZZ_WEBHOOK_SECRET=your-eduzz-secret

# Meta Ads API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-system-user-token   # System User da BM (não expira)
META_BM_ID=your-business-manager-id        # ID da sua Business Manager
META_SYNC_SECRET=your-sync-secret          # protege POST /api/sync/meta

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token   # Console de API Google Ads
GOOGLE_ADS_CLIENT_ID=your-client-id               # OAuth2 client ID
GOOGLE_ADS_CLIENT_SECRET=your-client-secret       # OAuth2 client secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token       # token de longa duração
GOOGLE_ADS_MANAGER_ID=your-mcc-id                 # ID da conta gerenciadora (MCC), opcional
GOOGLE_SYNC_SECRET=your-google-sync-secret        # protege POST /api/sync/google

# Google Sheets API (leitura de respostas de formulários pós-compra)
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key
