# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook secrets
RD_WEBHOOK_SECRET=your-rd-webhook-secret

# Meta Ads API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-system-user-token
META_BM_ID=your-business-manager-id
META_SYNC_SECRET=your-sync-secret

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_MANAGER_ID=your-mcc-id
GOOGLE_SYNC_SECRET=your-google-sync-secret

# Google Sheets API
GOOGLE_SHEETS_API_KEY=your-google-sheets-api-key

# Anthropic (Análises IA)
ANTHROPIC_API_KEY=your-anthropic-api-key
